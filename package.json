{
  "name": "@lpdfio/lpdf",
  "version": "0.0.0",
  "description": "Node.js SDK for Lpdf — PDF as Code on every platform. You describe a document as code or XML. Lpdf renders a compact, pixel-perfect PDF — identical across platforms.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types":   "./dist/index.d.ts"
    },
    "./browser": {
      "import": "./dist/browser.js",
      "types":  "./dist/browser.d.ts"
    }
  },
  "scripts": {
    "build":         "tsc && node build-browser.mjs && node -e \"require('node:fs').cpSync('./wasm', './dist/wasm', {recursive:true})\"",
    "build:node":    "tsc",
    "build:browser": "node build-browser.mjs",
    "test":          "node --test test/render.test.mjs"
  },
  "author": "lpdf.io",
  "homepage": "https://lpdf.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/lpdfio/lpdf-js"
  },
  "keywords": ["pdf", "wasm", "xml", "document", "lpdf"],
  "license": "SEE LICENSE IN LICENSE",
  "files": [
    "dist/"
  ],
  "devDependencies": {
    "@types/node": "^20.0.0",
    "esbuild":     "^0.25.0",
    "typescript":  "^5.0.0"
  }
}
